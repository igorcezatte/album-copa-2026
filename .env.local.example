# ── NextAuth ──────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=seu_secret_aqui

# Desenvolvimento local
NEXTAUTH_URL=http://localhost:3000

# Produção (Vercel)
# NEXTAUTH_URL=https://album-copa-2026-five.vercel.app

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com/apis/credentials
# Redirect URIs autorizadas:
#   - http://localhost:3000/api/auth/callback/google          (dev)
#   - https://seu-projeto.vercel.app/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── Supabase ───────────────────────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com → projeto → Settings → API
# Rode o schema em: supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx

# ── Upstash Redis (rate limiting) ──────────────────────────────────────────────
# Opcional mas recomendado em produção — protege contra DDoS
# Gratuito em: https://console.upstash.com → Create Database → REST API
# Sem essas variáveis o rate limiting é desativado (ok para dev local)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx
